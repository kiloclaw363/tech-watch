---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Veille technologique IT" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={import.meta.env.BASE_URL} class="logo">🦊 Tech Watch</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Veille tech par Yrlan · Alimenté par Astro 🚀</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f0f0f;
    --surface: #1a1a2e;
    --surface-hover: #222244;
    --text: #e0e0e0;
    --text-muted: #888;
    --accent: #7c3aed;
    --accent-light: #a78bfa;
    --border: #2a2a4a;
    --radius: 12px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }

  header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
  }

  nav {
    max-width: 900px;
    margin: 0 auto;
  }

  .logo {
    color: var(--accent-light);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.2rem;
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--text-muted);
  }

  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .tag {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    background: var(--surface);
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }

  .tag:hover, .tag.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card h2 {
    font-size: 1.2rem;
    margin: 0.5rem 0;
  }

  .card h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .card h2 a:hover {
    color: var(--accent-light);
  }

  .category-badge {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 0.7rem;
    padding: 0.15rem 0.6rem;
    border-radius: 10px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .meta {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .description {
    color: var(--text);
    margin-bottom: 1rem;
  }

  .source-link {
    color: var(--accent-light);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .source-link:hover {
    text-decoration: underline;
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--accent-light);
  }

  .article-full h1 {
    font-size: 1.8rem;
    margin: 0.5rem 0;
  }

  .content {
    margin-top: 2rem;
    line-height: 1.8;
  }

  .content h2 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .content p { margin-bottom: 1rem; }
  .content a { color: var(--accent-light); }
  .content code {
    background: var(--surface);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .content pre {
    background: var(--surface);
    padding: 1rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }

  @media (max-width: 600px) {
    main { padding: 1rem; }
    .hero h1 { font-size: 1.5rem; }
  }
</style>
