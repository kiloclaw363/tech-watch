---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, source, link, category } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title}>
  <a href={base} class="back-link">← Retour à l'accueil</a>
  <article class="article-full">
    <span class="category-badge">{category}</span>
    <h1>{title}</h1>
    <p class="meta">
      {pubDate.toLocaleDateString('fr-FR')} · {source}
    </p>
    <a href={link} target="_blank" rel="noopener" class="source-link">
      Lire l'article original →
    </a>
    <div class="content">
      <p>{description}</p>
    </div>
  </article>
</BaseLayout>
