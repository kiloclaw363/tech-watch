---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(posts.map(p => p.data.category))];
---

<BaseLayout title="Veille Tech IT">
  <div class="hero">
    <h1>🦊 Veille Technologique IT</h1>
    <p>IA · Cloud · DevOps · Sys/Réseaux · Cybersécurité</p>
  </div>

  <nav class="categories">
    <a href="/" class="tag active">Tout</a>
    {categories.map(cat => (
      <a href={`/category/${cat.toLowerCase()}`} class="tag">{cat}</a>
    ))}
  </nav>

  <section class="posts">
    {posts.map(post => (
      <article class="card">
        <span class="category-badge">{post.data.category}</span>
        <a href={`/blog/${post.slug}`}>
          <h2>{post.data.title}</h2>
        </a>
        <p class="meta">
          {post.data.pubDate.toLocaleDateString('fr-FR')} · {post.data.source}
        </p>
        <p class="description">{post.data.description}</p>
        <a href={post.data.link} target="_blank" rel="noopener" class="source-link">
          Lire la source →
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
