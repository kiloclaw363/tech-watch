---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = [...new Set(posts.map(p => p.data.category))];

  return categories.map(cat => ({
    params: { category: cat.toLowerCase() },
    props: {
      category: cat,
      posts: posts
        .filter(p => p.data.category === cat)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`${category} — Veille Tech IT`}`}>
  <a href="/" class="back-link">← Retour</a>
  <h1>{category}</h1>

  <section class="posts">
    {posts.map(post => (
      <article class="card">
        <a href={`/blog/${post.slug}`}>
          <h2>{post.data.title}</h2>
        </a>
        <p class="meta">
          {post.data.pubDate.toLocaleDateString('fr-FR')} · {post.data.source}
        </p>
        <p class="description">{post.data.description}</p>
        <a href={post.data.link} target="_blank" rel="noopener" class="source-link">
          Lire la source →
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
